# ─────────────────────────────────────────────────────────────
# myBuilds — Technical Submittal Automation System
# Copy to `.env` for local development:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Application
APP_NAME=myBuilds Submittal Automation System
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# NOTE: *_PORT below are HOST-side ports only (containers use standard ports
# internally). Defaults are shifted off the standard ports to avoid clashing
# with other services that may already run on the host.

# MariaDB
MARIADB_ROOT_PASSWORD=rootpassword
MARIADB_DATABASE=submittal_db
MARIADB_USER=submittal_user
MARIADB_PASSWORD=password
MARIADB_PORT=3400

# MongoDB
MONGODB_ADMIN_USER=admin
MONGODB_ADMIN_PASSWORD=password
MONGODB_DATABASE=submittal_db
MONGODB_PORT=27200

# Redis
REDIS_PASSWORD=password
REDIS_PORT=6500

# Backend
BACKEND_PORT=8100
FRONTEND_PORT=3100
DATABASE_URL=mysql+pymysql://submittal_user:password@mariadb:3306/submittal_db
MONGODB_URL=mongodb://admin:password@mongodb:27017/submittal_db?authSource=admin
REDIS_URL=redis://:password@redis:6379/0
CELERY_BROKER_URL=redis://:password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:password@redis:6379/2

# JWT
JWT_SECRET_KEY=dev-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI / LLM (optional for Phase 1 foundation)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost
ALLOWED_HOSTS=localhost,127.0.0.1

# File storage
FILE_STORAGE_TYPE=local
FILE_MAX_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf

# Seed admin (created by scripts/seed_data.py)
SEED_ADMIN_EMAIL=admin@mybuilds.com
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=Admin123!

# Frontend
VITE_API_URL=http://localhost:8100/api/v1
VITE_APP_NAME=myBuilds
